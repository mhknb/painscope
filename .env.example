# painscope environment variables
# Copy to .env and fill in your keys

# ── Required ──────────────────────────────────────────────────────────────
# OpenRouter API key for LLM calls (get one at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Reddit (via Xpoz) ─────────────────────────────────────────────────────
# Xpoz API key for Reddit data (https://xpoz.ai)
XPOZ_API_KEY=

# ── YouTube ──────────────────────────────────────────────────────────────
# Google Cloud → YouTube Data API v3 key
YOUTUBE_API_KEY=

# ── Product Hunt ─────────────────────────────────────────────────────────
# From https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=
PRODUCTHUNT_API_SECRET=

# ── LLM Models (optional overrides) ─────────────────────────────────────
# Default: openai/gpt-oss-20b:free (free, decent quality)
# Other free options: google/gemma-3-27b-it:free, mistralai/mistral-7b-instruct:free
LLM_MODEL_TR=openai/gpt-oss-20b:free
LLM_MODEL_EN=openai/gpt-oss-20b:free
LLM_MODEL_FALLBACK=openai/gpt-oss-20b:free
